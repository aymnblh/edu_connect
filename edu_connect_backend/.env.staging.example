# EduConnect Staging Environment Variables
# Use staging-only secrets and staging-only data. Never point this at production volumes.

APP_ENV=staging
DATABASE_URL=postgresql+asyncpg://edu_app:YOUR_STAGING_APP_DATABASE_PASSWORD@db:5432/edu_connect_staging
POSTGRES_SUPERUSER=postgres
POSTGRES_SUPERUSER_PASSWORD=YOUR_STAGING_POSTGRES_BOOTSTRAP_PASSWORD
APP_DB_USER=edu_app
APP_DB_PASSWORD=YOUR_STAGING_APP_DATABASE_PASSWORD
POSTGRES_DB=edu_connect_staging

PRIVATE_KEY_PATH=/app/secrets/private_key.pem
PUBLIC_KEY_PATH=/app/secrets/public_key.pem
JWT_ALGORITHM=RS256
MAX_ACTIVE_SESSION_FAMILIES=5

PLATFORM_SECRET=REPLACE_WITH_A_STAGING_ONLY_PLATFORM_SECRET
SERVER_FINGERPRINT_SALT=REPLACE_WITH_A_STAGING_ONLY_FINGERPRINT_SALT
AUDIT_RETENTION_DAYS=2555
SECURITY_ALERT_STATUS_CODES=401,403,429
SECURITY_ALERT_THRESHOLD=10
SECURITY_ALERT_WINDOW_SECONDS=300
SECURITY_ALERT_COOLDOWN_SECONDS=900

CORS_ORIGINS=https://staging-app.educonnect.dz
CREATE_TABLES_ON_STARTUP=false

REDIS_URL=redis://redis:6379/0
NTFY_BASE_URL=http://ntfy
NTFY_AUTH_TOKEN=REPLACE_WITH_STAGING_NTFY_ADMIN_TOKEN
NTFY_TOPIC_PREFIX=educonnect-staging

MEDIA_STORAGE_PATH=/app/private_media/attachments
MEDIA_UPLOADS_ENABLED=true
MEDIA_MAX_UPLOAD_BYTES=10485760
MEDIA_MALWARE_SCAN_ENABLED=true
MEDIA_MALWARE_SCAN_REQUIRED=true
CLAMAV_HOST=clamav
CLAMAV_PORT=3310
CLAMAV_TIMEOUT_SECONDS=15

FQDN=staging-api.educonnect.dz
ACME_EMAIL=admin@educonnect.dz
BACKUP_LOCAL_DIR=./backups
BACKUP_RETENTION_DAYS=7
