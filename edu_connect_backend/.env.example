DATABASE_URL=postgresql+asyncpg://edu_app:edu_password@db:5432/edu_connect
POSTGRES_SUPERUSER=postgres
POSTGRES_SUPERUSER_PASSWORD=postgres_password
APP_DB_USER=edu_app
APP_DB_PASSWORD=edu_password
POSTGRES_DB=edu_connect
APP_ENV=development
REDIS_URL=redis://redis:6379/0
PRIVATE_KEY_PATH=secrets/private_key.pem
PUBLIC_KEY_PATH=secrets/public_key.pem
PREVIOUS_PUBLIC_KEY_PATH=
SERVER_FINGERPRINT_SALT=change-this-local-fingerprint-salt
JWT_ALGORITHM=RS256
PLATFORM_SECRET=change-this-platform-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
MAX_ACTIVE_SESSION_FAMILIES=5
AUDIT_RETENTION_DAYS=2555
SECURITY_ALERT_STATUS_CODES=401,403,429
SECURITY_ALERT_THRESHOLD=10
SECURITY_ALERT_WINDOW_SECONDS=300
SECURITY_ALERT_COOLDOWN_SECONDS=900
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173
CREATE_TABLES_ON_STARTUP=false
NTFY_BASE_URL=http://ntfy
NTFY_AUTH_TOKEN=
NTFY_TOPIC_PREFIX=educonnect
MEDIA_STORAGE_PATH=media/attachments
MEDIA_MAX_UPLOAD_BYTES=10485760
MEDIA_MALWARE_SCAN_ENABLED=false
MEDIA_MALWARE_SCAN_REQUIRED=false
CLAMAV_HOST=clamav
CLAMAV_PORT=3310
CLAMAV_TIMEOUT_SECONDS=15
