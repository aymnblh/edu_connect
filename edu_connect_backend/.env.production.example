# EduConnect Production Environment Variables
# NEVER COMMIT THE ACTUAL .env FILE!

# 1. Database
# Internal docker name: db
APP_ENV=production
DATABASE_URL=postgresql+asyncpg://edu_app:YOUR_APP_DATABASE_PASSWORD@db:5432/edu_connect
POSTGRES_SUPERUSER=postgres
POSTGRES_SUPERUSER_PASSWORD=YOUR_POSTGRES_BOOTSTRAP_PASSWORD
APP_DB_USER=edu_app
APP_DB_PASSWORD=YOUR_APP_DATABASE_PASSWORD
POSTGRES_DB=edu_connect

# 2. Security (RS256)
# Paths inside the docker container
PRIVATE_KEY_PATH=/app/secrets/private_key.pem
PUBLIC_KEY_PATH=/app/secrets/public_key.pem
JWT_ALGORITHM=RS256
MAX_ACTIVE_SESSION_FAMILIES=5

# 3. Platform Secret (Manual Enrollment)
# A long random string, unique for this specific VPS environment
PLATFORM_SECRET=REPLACE_WITH_A_VERY_LONG_RANDOM_STRING_2026

# 4. Fingerprint & Audit
# Used for server-side fingerprint calculation
SERVER_FINGERPRINT_SALT=REPLACE_WITH_A_UNIQUE_SALT_FOR_THIS_SERVER
AUDIT_RETENTION_DAYS=2555
SECURITY_ALERT_STATUS_CODES=401,403,429
SECURITY_ALERT_THRESHOLD=10
SECURITY_ALERT_WINDOW_SECONDS=300
SECURITY_ALERT_COOLDOWN_SECONDS=900

# 4b. API hardening
CORS_ORIGINS=https://app.educonnect.dz
CREATE_TABLES_ON_STARTUP=false

# 5. Sovereign Notifications (ntfy)
# Internal docker name: ntfy
NTFY_BASE_URL=http://ntfy
NTFY_AUTH_TOKEN=REPLACE_WITH_NTFY_ADMIN_TOKEN
NTFY_TOPIC_PREFIX=educonnect

# 5b. Private media storage
# This directory must not be exposed as a static public web root.
MEDIA_STORAGE_PATH=/app/private_media/attachments
MEDIA_MAX_UPLOAD_BYTES=10485760
MEDIA_MALWARE_SCAN_ENABLED=true
MEDIA_MALWARE_SCAN_REQUIRED=true
CLAMAV_HOST=clamav
CLAMAV_PORT=3310
CLAMAV_TIMEOUT_SECONDS=15

# 6. Traefik (Domain)
# Used for Let's Encrypt and Routing
FQDN=api.educonnect.dz
ACME_EMAIL=admin@educonnect.dz

# 7. Sovereign Automated Backup
# Remote VPS for rsync-based data preservation
BACKUP_REMOTE_HOST=user@backup-vps-algeria
BACKUP_REMOTE_PATH=/backups/educonnect/
BACKUP_LOCAL_DIR=./backups
BACKUP_RETENTION_DAYS=35
