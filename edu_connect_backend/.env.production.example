# EduConnect Production Environment Variables
# NEVER COMMIT THE ACTUAL .env FILE!

# 1. Database
# Internal docker name: db
DATABASE_URL=postgresql+asyncpg://edu_user:YOUR_DATABASE_PASSWORD@db:5432/edu_connect
POSTGRES_USER=edu_user
POSTGRES_PASSWORD=YOUR_DATABASE_PASSWORD
POSTGRES_DB=edu_connect

# 2. Security (RS256)
# Paths inside the docker container
PRIVATE_KEY_PATH=/app/secrets/private_key.pem
PUBLIC_KEY_PATH=/app/secrets/public_key.pem
JWT_ALGORITHM=RS256

# 3. Platform Secret (Manual Enrollment)
# A long random string, unique for this specific VPS environment
PLATFORM_SECRET=REPLACE_WITH_A_VERY_LONG_RANDOM_STRING_2026

# 4. Fingerprint & Audit
# Used for server-side fingerprint calculation
SERVER_FINGERPRINT_SALT=REPLACE_WITH_A_UNIQUE_SALT_FOR_THIS_SERVER

# 5. Sovereign Notifications (ntfy)
# Internal docker name: ntfy
NTFY_BASE_URL=http://ntfy
NTFY_AUTH_TOKEN=REPLACE_WITH_NTFY_ADMIN_TOKEN
NTFY_TOPIC_PREFIX=educonnect

# 6. Traefik (Domain)
# Used for Let's Encrypt and Routing
FQDN=api.educonnect.dz
ACME_EMAIL=admin@educonnect.dz

# 7. Sovereign Automated Backup
# Remote VPS for rsync-based data preservation
BACKUP_REMOTE_HOST=user@backup-vps-algeria
BACKUP_REMOTE_PATH=/backups/educonnect/
